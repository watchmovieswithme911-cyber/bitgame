# ============================================
# BitGame Configuration
# ============================================
# Copy this file to .env and fill in your values

# Your Bitcoin wallet address — ALL payments & commission go here
SELLER_WALLET=1QLTRW2YLBcwWJbCb1imGgwp98cSrUhNGJ

# Commission rate (5% = 0.05)
COMMISSION_RATE=0.05

# Network: mainnet or testnet
NETWORK=mainnet
CHAIN_NETWORK=BitcoinMain

# ============================================
# BTCPay Server Configuration
# ============================================
# After setting up BTCPay Server, get these values:
# 1. BTCPay URL: Your BTCPay server address
# 2. API Key: Generate in BTCPay → Account → API Keys
# 3. Store ID: Create a store in BTCPay → Stores

BTCPAY_HOST=btcpay.yourdomain.com
BTCPAY_URL=http://btcpayserver:80
BTCPAY_API_KEY=your-api-key-here
BTCPAY_STORE_ID=your-store-id-here
